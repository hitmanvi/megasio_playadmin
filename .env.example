APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost:3000
# Default currency when API omits currency (e.g. POST /airdrops); matches config app.currency
APP_CURRENCY=USD

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=playadmin
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

SOPAY_ENDPOINT=
SOPAY_APP_ID=
SOPAY_APP_KEY=
SOPAY_CALLBACK_URL=
SOPAY_RETURN_URL=

# 后台调用 Play API（如 KYC 通知等，见 config/services.php play_api_admin）
PLAY_API_ADMIN_BASE_URL=
PLAY_API_ADMIN_API_KEY=

# Customer.io（Track API，见 config/services.php customer_io）
CUSTOMER_IO_ENABLED=false
CUSTOMER_IO_SITE_ID=
CUSTOMER_IO_API_KEY=
CUSTOMER_IO_WEBHOOK_URL=

# OpenSearch（统计事件聚合，兼容 AWS OpenSearch）
OPENSEARCH_ENABLED=false
OPENSEARCH_HOSTS=http://localhost:9200
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_PREFIX=playapi
OPENSEARCH_CONNECT_TIMEOUT=5
OPENSEARCH_REQUEST_TIMEOUT=30
OPENSEARCH_DEBUG=false
# OPENSEARCH_LOG_REQUESTS=true