{
    "/password": {
        "put": {
            "tags": [
                "Admin Authentication"
            ],
            "summary": "Update admin password",
            "description": "Update password for the currently authenticated admin",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "current_password",
                                "password",
                                "password_confirmation"
                            ],
                            "properties": {
                                "current_password": {
                                    "type": "string",
                                    "description": "当前密码"
                                },
                                "password": {
                                    "type": "string",
                                    "minLength": 6,
                                    "description": "新密码"
                                },
                                "password_confirmation": {
                                    "type": "string",
                                    "description": "确认新密码"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Password updated successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "updated": {
                                                "type": "boolean",
                                                "example": true
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error or invalid current password",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}