                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Bundle updated successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Bundle"
                                    }
                                }
                            }
                        }
                    }
