{
    "/bundles": {
        "get": {
            "tags": [
                "Bundles"
            ],
            "summary": "Get bundles list",
            "description": "Get paginated list of bundles with optional filtering",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "name",
                    "in": "query",
                    "description": "Filter bundles by name (partial match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "enabled",
                    "in": "query",
                    "description": "Filter bundles by enabled status",
                    "required": false,
                    "schema": {
                        "type": "boolean"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Bundles list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "list": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Bundle"
                                                }
                                            },
                                            "total": {
                                                "type": "integer"
                                            },
                                            "page": {
                                                "type": "integer"
                                            },
                                            "per_page": {
                                                "type": "integer"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Bundles"
            ],
            "summary": "Create a new bundle",
            "description": "Create a new bundle with pricing and coin amounts",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "name",
                                "original_price"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle name"
                                },
                                "display_name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle display name",
                                    "nullable": true
                                },
                                "description": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle description",
                                    "nullable": true
                                },
                                "icon": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle icon URL",
                                    "nullable": true
                                },
                                "gold_coin": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Amount of GoldCoin included"
                                },
                                "social_coin": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Amount of SocialCoin included"
                                },
                                "original_price": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Original price"
                                },
                                "discount_price": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Discount price",
                                    "nullable": true
                                },
                                "currency": {
                                    "type": "string",
                                    "maxLength": 10,
                                    "default": "USD",
                                    "description": "Payment currency"
                                },
                                "stock": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Stock quantity, null for unlimited",
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "default": true,
                                    "description": "Whether the bundle is enabled"
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "default": 0,
                                    "description": "Sort order"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Bundle created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Bundle"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/bundles/{bundle}": {
