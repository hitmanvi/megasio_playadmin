                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle name"
                                },
                                "display_name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle display name",
                                    "nullable": true
                                },
                                "description": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle description",
                                    "nullable": true
                                },
                                "icon": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Bundle icon URL",
                                    "nullable": true
                                },
                                "gold_coin": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Amount of GoldCoin included"
                                },
                                "social_coin": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Amount of SocialCoin included"
                                },
                                "original_price": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Original price"
                                },
                                "discount_price": {
                                    "type": "number",
                                    "minimum": 0,
                                    "description": "Discount price",
                                    "nullable": true
                                },
                                "currency": {
                                    "type": "string",
                                    "maxLength": 10,
                                    "description": "Payment currency"
                                },
                                "stock": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "description": "Stock quantity, null for unlimited",
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
