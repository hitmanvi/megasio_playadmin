{
    "/bonus-tasks": {
        "get": {
            "tags": [
                "Bonus Tasks"
            ],
            "summary": "List bonus tasks",
            "description": "Paginated bonus_tasks; optional filters by users.id and status (single value or multiple)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "user_id",
                    "in": "query",
                    "description": "Filter by user id (users.id)",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "Filter by bonus_tasks.status (repeat param or array for multiple)",
                    "required": false,
                    "style": "form",
                    "explode": true,
                    "schema": {
                        "oneOf": [
                            {
                                "type": "string",
                                "enum": [
                                    "pending",
                                    "active",
                                    "completed",
                                    "claimed",
                                    "expired",
                                    "cancelled",
                                    "depleted"
                                ]
                            },
                            {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "enum": [
                                        "pending",
                                        "active",
                                        "completed",
                                        "claimed",
                                        "expired",
                                        "cancelled",
                                        "depleted"
                                    ]
                                }
                            }
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "List retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/BonusTask"
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 0
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/bonus-tasks/stats": {
        "get": {
            "tags": [
                "Bonus Tasks"
            ],
            "summary": "Bonus task aggregates",
            "description": "total_base_bonus (sum of base_bonus for all matching rows) and total_claimed (sum of base_bonus where status=claimed). Optional user_id scopes both.",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "user_id",
                    "in": "query",
                    "description": "If set, only include bonus_tasks for this users.id",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Stats retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/BonusTaskStats"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
