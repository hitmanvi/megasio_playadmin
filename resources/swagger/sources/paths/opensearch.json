{
    "/opensearch/stats/user-deposit-withdraw-totals": {
        "get": {
            "tags": ["OpenSearch"],
            "summary": "用户充提金额汇总",
            "description": "从 OpenSearch 获取每个用户的充值/提现金额、首次/末次成功充值时间及用户基本信息。支持分页与排序。需开启 OPENSEARCH_ENABLED 并配置连接。",
            "security": [{ "sanctum": [] }],
            "parameters": [
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "required": false,
                    "schema": { "type": "integer", "minimum": 1, "default": 1 }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页条数",
                    "required": false,
                    "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 15 }
                },
                {
                    "name": "uid",
                    "in": "query",
                    "description": "按用户 uid 筛选",
                    "required": false,
                    "schema": { "type": "string" }
                },
                {
                    "name": "date_from",
                    "in": "query",
                    "description": "起始日期",
                    "required": false,
                    "schema": { "type": "string", "format": "date" }
                },
                {
                    "name": "date_to",
                    "in": "query",
                    "description": "结束日期",
                    "required": false,
                    "schema": { "type": "string", "format": "date" }
                },
                {
                    "name": "agent_id",
                    "in": "query",
                    "description": "按代理 ID 筛选",
                    "required": false,
                    "schema": { "type": "integer" }
                },
                {
                    "name": "agent_link_id",
                    "in": "query",
                    "description": "按推广链接 ID 筛选",
                    "required": false,
                    "schema": { "type": "integer" }
                },
                {
                    "name": "sort_by",
                    "in": "query",
                    "description": "排序字段：user_id（默认）| deposit_total | deposit_completed_total | withdraw_total | withdraw_completed_total | deposit_minus_withdraw（充值创建总额-提现创建总额）| deposit_completed_minus_withdraw_completed（成功充值-成功提现）",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "user_id",
                            "deposit_total",
                            "deposit_completed_total",
                            "withdraw_total",
                            "withdraw_completed_total",
                            "deposit_minus_withdraw",
                            "deposit_completed_minus_withdraw_completed"
                        ],
                        "default": "user_id"
                    }
                },
                {
                    "name": "sort_order",
                    "in": "query",
                    "description": "asc 升序 / desc 降序",
                    "required": false,
                    "schema": { "type": "string", "enum": ["asc", "desc"], "default": "asc" }
                }
            ],
            "responses": {
                "200": {
                    "description": "成功",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": { "type": "integer", "example": 0 },
                                    "errmsg": { "type": "string" },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "description": "当前页：每用户一条（已按 sort_by/sort_order 排序）",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "user_id": { "type": "integer", "description": "用户 ID" },
                                                        "user": {
                                                            "type": "object",
                                                            "nullable": true,
                                                            "description": "用户基本信息",
                                                            "properties": {
                                                                "id": { "type": "integer" },
                                                                "name": { "type": "string" },
                                                                "email": { "type": "string", "nullable": true },
                                                                "phone": { "type": "string", "nullable": true },
                                                                "status": { "type": "string" }
                                                            }
                                                        },
                                                        "first_deposit_at": { "type": "string", "format": "date-time", "nullable": true, "description": "首次成功充值时间（来自数据库，与请求时间范围无关）" },
                                                        "last_deposit_at": { "type": "string", "format": "date-time", "nullable": true, "description": "最后一次成功充值时间（来自数据库，与请求时间范围无关）" },
                                                        "deposit_total": { "type": "number" },
                                                        "withdraw_total": { "type": "number" },
                                                        "deposit_completed_total": { "type": "number" },
                                                        "withdraw_completed_total": { "type": "number" }
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": { "type": "integer" },
                                            "last_page": { "type": "integer" },
                                            "total": { "type": "integer" }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                        }
                    }
                },
                "500": {
                    "description": "OpenSearch 未启用或连接失败",
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                        }
                    }
                }
            }
        }
    },
    "/opensearch/stats/daily": {
        "get": {
            "tags": ["OpenSearch"],
            "summary": "按日统计（按时区聚合）",
            "description": "按所给时区进行日期聚合，支持过滤 agent_id、agent_link_id、日期范围。返回每日：DAU、注册用户数、首充用户数、充值成功人数、总成功充值金额、总提现金额、今日注册用户充值金额、今日首充用户充值金额。",
            "security": [{ "sanctum": [] }],
            "parameters": [
                {
                    "name": "timezone",
                    "in": "query",
                    "description": "时区，如 Asia/Shanghai、UTC+8",
                    "required": true,
                    "schema": { "type": "string", "example": "Asia/Shanghai" }
                },
                {
                    "name": "date_from",
                    "in": "query",
                    "description": "起始日期",
                    "required": false,
                    "schema": { "type": "string", "format": "date" }
                },
                {
                    "name": "date_to",
                    "in": "query",
                    "description": "结束日期",
                    "required": false,
                    "schema": { "type": "string", "format": "date" }
                },
                {
                    "name": "agent_id",
                    "in": "query",
                    "description": "按代理 ID 筛选",
                    "required": false,
                    "schema": { "type": "integer" }
                },
                {
                    "name": "agent_link_id",
                    "in": "query",
                    "description": "按推广链接 ID 筛选",
                    "required": false,
                    "schema": { "type": "integer" }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "页码",
                    "required": false,
                    "schema": { "type": "integer", "minimum": 1, "default": 1 }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "每页条数",
                    "required": false,
                    "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 15 }
                }
            ],
            "responses": {
                "200": {
                    "description": "成功",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": { "type": "integer", "example": 0 },
                                    "errmsg": { "type": "string" },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "description": "当前页：按日期分桶的每日统计",
                                                "items": {
                                                    "type": "object",
                                                    "properties": {
                                                        "date": { "type": "string", "description": "日期 Y-m-d（按时区）" },
                                                        "dau": { "type": "integer", "description": "当日有登录行为的用户数" },
                                                        "registered_count": { "type": "integer", "description": "注册用户数" },
                                                        "first_deposit_users_count": { "type": "integer", "description": "有首次充值的新用户数" },
                                                        "registered_and_first_deposit_count": { "type": "integer", "description": "今天注册且有首充的人数" },
                                                        "deposit_completed_users_count": { "type": "integer", "description": "充值成功人数" },
                                                        "deposit_created_count": { "type": "integer", "description": "创建充值订单个数" },
                                                        "deposit_completed_count": { "type": "integer", "description": "完成充值订单个数" },
                                                        "withdraw_completed_count": { "type": "integer", "description": "完成提现订单个数" },
                                                        "deposit_amount": { "type": "number", "description": "总成功充值金额" },
                                                        "withdraw_amount": { "type": "number", "description": "总提现金额" },
                                                        "registered_users_deposit_amount": { "type": "number", "description": "今日注册用户的充值金额" },
                                                        "first_deposit_users_deposit_amount": { "type": "number", "description": "今日发生首充的用户的充值金额" }
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": { "type": "integer" },
                                            "last_page": { "type": "integer" },
                                            "total": { "type": "integer" }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                        }
                    }
                },
                "422": {
                    "description": "参数校验失败（如缺少 timezone）",
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                        }
                    }
                },
                "500": {
                    "description": "OpenSearch 未启用或连接失败",
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
                        }
                    }
                }
            }
        }
    }
}
