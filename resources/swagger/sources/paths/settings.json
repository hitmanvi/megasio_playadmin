{
    "/settings": {
        "get": {
            "tags": [
                "Settings"
            ],
            "summary": "Get settings list",
            "description": "Get paginated list of settings with optional filtering by group, key, or type",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "key",
                    "in": "query",
                    "description": "Filter settings by key (partial match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "group",
                    "in": "query",
                    "description": "Filter settings by group",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "type",
                    "in": "query",
                    "description": "Filter settings by type",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "string",
                            "integer",
                            "boolean",
                            "json",
                            "array"
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Settings list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "list": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Setting"
                                                }
                                            },
                                            "total": {
                                                "type": "integer"
                                            },
                                            "page": {
                                                "type": "integer"
                                            },
                                            "per_page": {
                                                "type": "integer"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Settings"
            ],
            "summary": "Create a new setting",
            "description": "Create a new setting with key, value, type, group and description",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "key"
                            ],
                            "properties": {
                                "key": {
                                    "type": "string",
                                    "maxLength": 100,
                                    "description": "Unique setting key"
                                },
                                "value": {
                                    "description": "Setting value",
                                    "nullable": true
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "string",
                                        "integer",
                                        "boolean",
                                        "json",
                                        "array"
                                    ],
                                    "default": "string",
                                    "description": "Value type"
                                },
                                "group": {
                                    "type": "string",
                                    "maxLength": 50,
                                    "default": "general",
                                    "description": "Setting group"
                                },
                                "description": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Setting description",
                                    "nullable": true
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "minimum": 0,
                                    "default": 0,
                                    "description": "Sort order"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Setting created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Setting"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/settings/batch": {
        "post": {
            "tags": [
                "Settings"
            ],
            "summary": "Batch update settings",
            "description": "Update multiple settings at once by key",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "settings"
                            ],
                            "properties": {
                                "settings": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "required": [
                                            "key"
                                        ],
                                        "properties": {
                                            "key": {
                                                "type": "string",
                                                "description": "Setting key"
                                            },
                                            "value": {
                                                "description": "New value",
                                                "nullable": true
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Settings updated successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "updated": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Setting"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/settings/{setting}": {
