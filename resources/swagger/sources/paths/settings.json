                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "value": {
                                    "description": "Setting value",
                                    "nullable": true
                                },
                                "type": {
                                    "type": "string",
                                    "enum": [
                                        "string",
                                        "integer",
