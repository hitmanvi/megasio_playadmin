{
    "/promotion-codes/options": {
        "get": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "Promotion code filter options",
            "description": "Returns bonus_type options (type) and list status filter options (status)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "responses": {
                "200": {
                    "description": "types and statuses for filters",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/PromotionCodeFilterOptions"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/promotion-codes": {
        "get": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "List promotion codes",
            "description": "Paginated list; optional filters: name (partial LIKE), code (exact), bonus_type, status (active/inactive/exhausted match column; expired = expired_at set and past)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "name",
                    "in": "query",
                    "description": "Partial match on promotion_codes.name",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                {
                    "name": "code",
                    "in": "query",
                    "description": "Exact match on promotion_codes.code",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                {
                    "name": "bonus_type",
                    "in": "query",
                    "description": "Exact match on promotion_codes.bonus_type",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "bonus_task"
                        ]
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "active/inactive/exhausted: match status column; expired: expired_at is set and not after now",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "inactive",
                            "exhausted",
                            "expired"
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Promotion codes list",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/PromotionCode"
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 0
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
