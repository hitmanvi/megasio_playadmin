{
    "/promotion-codes/options/type": {
        "get": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "Promotion code bonus_type options",
            "description": "Returns bonus_type string values for list filters; data is the array directly",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "responses": {
                "200": {
                    "description": "bonus_type options",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "array",
                                        "description": "bonus_type values (e.g. bonus_task)",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/promotion-codes/options/status": {
        "get": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "Promotion code status filter options",
            "description": "Returns status filter string values for list filters; data is the array directly (includes virtual expired)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "responses": {
                "200": {
                    "description": "status options",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "array",
                                        "description": "active, inactive, exhausted, expired",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/promotion-codes": {
        "get": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "List promotion codes",
            "description": "Paginated list; optional filters: name (partial LIKE), code (exact), bonus_type, status (active/inactive/exhausted match column; expired = expired_at set and past)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "name",
                    "in": "query",
                    "description": "Partial match on promotion_codes.name",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                {
                    "name": "code",
                    "in": "query",
                    "description": "Exact match on promotion_codes.code",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 255
                    }
                },
                {
                    "name": "bonus_type",
                    "in": "query",
                    "description": "Exact match on promotion_codes.bonus_type",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "bonus_task"
                        ]
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "active/inactive/exhausted: match status column; expired: expired_at is set and not after now",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "inactive",
                            "exhausted",
                            "expired"
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Promotion codes list",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/PromotionCode"
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 0
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "Create promotion code",
            "description": "Creates a code with claimed_count 0. status may be active or inactive (default active). code must be unique. If uids is non-empty and target_type is not all, inserts one pending promotion_code_claim per resolved users.uid; optional uid_valid_days sets each new claim expired_at to now + that many days.",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/PromotionCodeCreateRequest"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Created promotion code",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/PromotionCode"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error (e.g. duplicate code)",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/promotion-codes/{promotionCode}": {
        "put": {
            "tags": [
                "Promotion Codes"
            ],
            "summary": "Update promotion code",
            "description": "Partial update. If uids is provided: creates pending claims for new users, or updates expired_at on existing claims for this code; must not be used when target_type is all. uid_valid_days sets expired_at to now + that many days (omit/null clears to null).",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "promotionCode",
                    "in": "path",
                    "required": true,
                    "description": "promotion_codes.id",
                    "schema": {
                        "type": "integer",
                        "minimum": 1
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "#/components/schemas/PromotionCodeUpdateRequest"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Updated promotion code",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/PromotionCode"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Promotion code not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}
