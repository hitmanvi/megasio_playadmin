{
    "/agent-links": {
        "get": {
            "tags": [
                "Agent Links"
            ],
            "summary": "获取推广链接列表",
            "description": "分页获取推广链接，支持按 agent_id、名称、推广码、状态筛选",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "agent_id",
                    "in": "query",
                    "description": "按代理 ID 筛选",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "name",
                    "in": "query",
                    "description": "按名称模糊筛选",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "promotion_code",
                    "in": "query",
                    "description": "按推广码筛选（4位纯字母）",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "minLength": 4,
                        "maxLength": 4
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "按状态筛选",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "inactive"
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "推广链接列表",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/AgentLink"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer"
                                                    },
                                                    "last_page": {
                                                        "type": "integer"
                                                    },
                                                    "total": {
                                                        "type": "integer"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Agent Links"
            ],
            "summary": "创建推广链接",
            "description": "推广码（promotion_code）由服务端自动生成 4 位纯字母唯一码，无需传入",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "agent_id",
                                "name"
                            ],
                            "properties": {
                                "agent_id": {
                                    "type": "integer",
                                    "description": "代理 ID"
                                },
                                "name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "链接名称"
                                },
                                "status": {
                                    "type": "string",
                                    "enum": [
                                        "active",
                                        "inactive"
                                    ],
                                    "default": "active"
                                },
                                "facebook_config": {
                                    "type": "object",
                                    "nullable": true
                                },
                                "kochava_config": {
                                    "type": "object",
                                    "nullable": true
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "创建成功",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer"
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/AgentLink"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "校验失败",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/agent-links/{agentLink}": {
        "get": {
            "tags": [
                "Agent Links"
            ],
            "summary": "获取推广链接详情",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "agentLink",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    },
                    "description": "推广链接 ID"
                }
            ],
            "responses": {
                "200": {
                    "description": "推广链接详情",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer"
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/AgentLink"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "未找到",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "put": {
            "tags": [
                "Agent Links"
            ],
            "summary": "更新推广链接",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "agentLink",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    },
                    "description": "推广链接 ID"
                }
            ],
            "requestBody": {
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "maxLength": 255
                                },
                                "promotion_code": {
                                    "type": "string",
                                    "minLength": 4,
                                    "maxLength": 4,
                                    "pattern": "^[A-Za-z]{4}$"
                                },
                                "status": {
                                    "type": "string",
                                    "enum": [
                                        "active",
                                        "inactive"
                                    ]
                                },
                                "facebook_config": {
                                    "type": "object",
                                    "nullable": true
                                },
                                "kochava_config": {
                                    "type": "object",
                                    "nullable": true
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "更新成功",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer"
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/AgentLink"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "未找到",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "校验失败",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "delete": {
            "tags": [
                "Agent Links"
            ],
            "summary": "删除推广链接",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "agentLink",
                    "in": "path",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    },
                    "description": "推广链接 ID"
                }
            ],
            "responses": {
                "200": {
                    "description": "删除成功",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer"
                                    },
                                    "errmsg": {
                                        "type": "string"
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "deleted": {
                                                "type": "boolean",
                                                "example": true
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "未授权",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "未找到",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}