{
    "/tags": {
        "get": {
            "tags": [
                "Tags"
            ],
            "summary": "Get tags list",
            "description": "Get paginated list of tags with optional filtering",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "name",
                    "in": "query",
                    "description": "Filter tags by name (partial match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "enabled",
                    "in": "query",
                    "description": "Filter tags by enabled status",
                    "required": false,
                    "schema": {
                        "type": "boolean"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Tags list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "list": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Tag"
                                                }
                                            },
                                            "total": {
                                                "type": "integer"
                                            },
                                            "page": {
                                                "type": "integer"
                                            },
                                            "per_page": {
                                                "type": "integer"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Tags"
            ],
            "summary": "Create a new tag",
            "description": "Create a new tag",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "name"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Tag name (unique)"
                                },
                                "display_name": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Display name",
                                    "nullable": true
                                },
                                "color": {
                                    "type": "string",
                                    "maxLength": 20,
                                    "description": "Color (e.g. #FF5733)",
                                    "nullable": true
                                },
                                "description": {
                                    "type": "string",
                                    "maxLength": 255,
                                    "description": "Description",
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "default": true,
                                    "description": "Whether the tag is enabled"
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "default": 0,
                                    "description": "Sort order"
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Tag created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Tag"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
