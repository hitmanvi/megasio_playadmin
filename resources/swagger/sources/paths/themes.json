{
    "/themes": {
        "get": {
            "tags": [
                "Themes"
            ],
            "summary": "Get themes list",
            "description": "Get paginated list of themes with optional filtering; each item includes translations (locale -> name)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "ids",
                    "in": "query",
                    "description": "Filter themes by IDs (supports multiple values)",
                    "required": false,
                    "schema": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        }
                    },
                    "style": "form",
                    "explode": true
                },
                {
                    "name": "name",
                    "in": "query",
                    "description": "Filter themes by name",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "enabled",
                    "in": "query",
                    "description": "Filter themes by enabled status",
                    "required": false,
                    "schema": {
                        "type": "boolean"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Themes list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Theme"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "last_page": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "total": {
                                                        "type": "integer",
                                                        "example": 100
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 10
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 100
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Themes"
            ],
            "summary": "Create theme",
            "description": "Create a new theme with name translations (same pattern as game categories)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "translations"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Optional base theme name",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "icon": {
                                    "type": "string",
                                    "description": "Theme icon",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "description": "Whether theme is enabled",
                                    "nullable": true
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "description": "Sort order",
                                    "minimum": 0,
                                    "nullable": true
                                },
                                "translations": {
                                    "type": "object",
                                    "description": "Translations for the theme name",
                                    "additionalProperties": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "example": {
                                        "en": "Classic",
                                        "zh-CN": "经典"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Theme created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Theme"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/themes/{id}": {
        "get": {
            "tags": [
                "Themes"
            ],
            "summary": "Get theme details",
            "description": "Get detailed information about a specific theme including translations",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "description": "Theme ID",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Theme details retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Theme"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Theme not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "put": {
            "tags": [
                "Themes"
            ],
            "summary": "Update theme",
            "description": "Update theme; translations replaces all name translations for the theme (same as game categories)",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "description": "Theme ID",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "translations"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Base theme name",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "icon": {
                                    "type": "string",
                                    "description": "Theme icon",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "description": "Whether theme is enabled",
                                    "nullable": true
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "description": "Sort order",
                                    "minimum": 0,
                                    "nullable": true
                                },
                                "translations": {
                                    "type": "object",
                                    "description": "Full set of name translations",
                                    "additionalProperties": {
                                        "type": "string",
                                        "maxLength": 255
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Theme updated successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/Theme"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Theme not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}