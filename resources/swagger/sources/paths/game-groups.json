{
    "/game-groups": {
        "get": {
            "tags": [
                "Game Groups"
            ],
            "summary": "Get game groups list",
            "description": "Get paginated list of game groups with optional filtering",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "category",
                    "in": "query",
                    "description": "Filter game groups by category (Event, System)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "enabled",
                    "in": "query",
                    "description": "Filter game groups by enabled status",
                    "required": false,
                    "schema": {
                        "type": "boolean"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Game groups list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/GameGroup"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "last_page": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "total": {
                                                        "type": "integer",
                                                        "example": 100
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 10
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 100
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Game Groups"
            ],
            "summary": "Create game group",
            "description": "Create a new game group",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "category"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Game group name",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "category": {
                                    "type": "string",
                                    "description": "Category (Event, System)",
                                    "maxLength": 255
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "description": "Sort order",
                                    "minimum": 0
                                },
                                "app_limit": {
                                    "type": "integer",
                                    "description": "App display limit",
                                    "minimum": 0,
                                    "nullable": true
                                },
                                "web_limit": {
                                    "type": "integer",
                                    "description": "Web display limit",
                                    "minimum": 0,
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "description": "Whether game group is enabled"
                                },
                                "translations": {
                                    "type": "object",
                                    "description": "Translations for the game group name in {locale: value} format",
                                    "additionalProperties": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "example": {
                                        "en": "New Games",
                                        "zh-CN": "新游戏",
                                        "ja": "新規ゲーム"
                                    },
                                    "nullable": true
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Game group created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/GameGroup"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
