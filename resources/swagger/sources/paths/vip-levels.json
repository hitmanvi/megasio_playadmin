                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "list": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/VipLevel"
                                                }
                                            },
                                            "total": {
                                                "type": "integer"
