{
    "/users": {
        "get": {
            "tags": [
                "Users"
            ],
            "summary": "Get users list",
            "description": "Get paginated list of users with optional filtering",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "account",
                    "in": "query",
                    "description": "Filter users by email or phone",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "uid",
                    "in": "query",
                    "description": "Filter users by uid (exact match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "email",
                    "in": "query",
                    "description": "Filter users by email (partial match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "agent_id",
                    "in": "query",
                    "description": "Filter users by agent ID",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "agent_link_id",
                    "in": "query",
                    "description": "Filter users by agent link ID",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "tag_id",
                    "in": "query",
                    "description": "Filter users that have this tag",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "Filter users by status",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "banned"
                        ]
                    }
                },
                {
                    "name": "registered_at_from",
                    "in": "query",
                    "description": "Filter users registered on or after this date (Y-m-d)",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "registered_at_to",
                    "in": "query",
                    "description": "Filter users registered on or before this date (Y-m-d)",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "balance_min",
                    "in": "query",
                    "description": "Filter users with total balance (available + frozen) >= this value",
                    "required": false,
                    "schema": {
                        "type": "number"
                    }
                },
                {
                    "name": "balance_max",
                    "in": "query",
                    "description": "Filter users with total balance (available + frozen) <= this value",
                    "required": false,
                    "schema": {
                        "type": "number"
                    }
                },
                {
                    "name": "balance_currency",
                    "in": "query",
                    "description": "When set, balance_min/balance_max apply to this currency only",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 16
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Users list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/User"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "last_page": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "total": {
                                                        "type": "integer",
                                                        "example": 100
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 10
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 100
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/users/{user}/ban": {
        "post": {
            "tags": [
                "Users"
            ],
            "summary": "Ban a user",
            "description": "Ban a user by setting banned status to true",
