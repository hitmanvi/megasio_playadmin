            ],
            "summary": "Invitation rewards aggregated by invitation",
            "description": "Paginated invitations where the user is inviter; each item includes rewards_by_source_type (SUM(reward_amount) per invitation_rewards.source_type for that invitation). Optional account filters invitee by users.uid (exact) or email/phone (partial, same as user list). Optional status filters invitee users.status (active/banned). Path uses users.uid.",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "uid",
                    "in": "path",
                    "description": "User uid (users.uid)",
                    "required": true,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "account",
                    "in": "query",
                    "description": "Filter invitee: users.uid exact match, or email/phone partial (User::byAccount)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "Filter invitee users.status",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "banned"
                        ]
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Aggregates retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
