{
    "/users": {
        "get": {
            "tags": [
                "Users"
            ],
            "summary": "Get users list",
            "description": "Get paginated list of users with optional filtering",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "account",
                    "in": "query",
                    "description": "Filter by account: uid (exact match) or email/phone (partial match)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "agent_id",
                    "in": "query",
                    "description": "Filter users by agent ID",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "agent_link_id",
                    "in": "query",
                    "description": "Filter users by agent link ID",
                    "required": false,
                    "schema": {
                        "type": "integer"
                    }
                },
                {
                    "name": "tag_id",
                    "in": "query",
                    "description": "Filter users that have this tag",
                    "required": false,

                    "schema": {

                        "type": "integer"
                    }
                },
                {
                    "name": "status",
                    "in": "query",
                    "description": "Filter users by status",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "enum": [
                            "active",
                            "banned"
                        ]
                    }
                },
                {
                    "name": "registered_at_from",
                    "in": "query",
                    "description": "Filter users registered on or after this date (Y-m-d)",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "registered_at_to",
                    "in": "query",
                    "description": "Filter users registered on or before this date (Y-m-d)",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "format": "date"
                    }
                },
                {
                    "name": "balance_min",
                    "in": "query",
                    "description": "Filter users with total balance (available + frozen) >= this value",
                    "required": false,
                    "schema": {
                        "type": "number"
                    }
                },
                {
                    "name": "balance_max",
                    "in": "query",
                    "description": "Filter users with total balance (available + frozen) <= this value",
                    "required": false,
                    "schema": {
                        "type": "number"
                    }
                },
                {
                    "name": "balance_currency",
                    "in": "query",
                    "description": "When set, balance_min/balance_max apply to this currency only",
                    "required": false,
                    "schema": {
                        "type": "string",
                        "maxLength": 16
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Users list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/User"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "last_page": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "total": {
                                                        "type": "integer",
                                                        "example": 100
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 10
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 100
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/users/{uid}": {
        "get": {
            "tags": [
                "Users"
            ],
            "summary": "Get user detail",
            "description": "Admin user detail: activity, profile (email/phone/KYC/birthdate), referral (agent, agent_link, inviter, invite_count, invitation_reward deposit bonus starter/advanced counts), payment_extra_info (counts by type + duplicate_across_user), user_meta (latest register_info / latest_info JSON from user_metas), finance (balances, total deposit/withdraw by currency), VIP from user_vips + level config, bonus (reward totals by category from transactions). Path uses users.uid (not numeric id).",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "uid",
                    "in": "path",
                    "description": "User uid (users.uid)",
                    "required": true,
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "User detail retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/UserDetail"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "User not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
