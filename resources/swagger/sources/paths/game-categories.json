{
    "/game-categories": {
        "get": {
            "tags": [
                "Game Categories"
            ],
            "summary": "Get game categories list",
            "description": "Get paginated list of game categories with optional filtering and translations",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "ids",
                    "in": "query",
                    "description": "Filter categories by IDs (supports multiple values)",
                    "required": false,
                    "schema": {
                        "type": "array",
                        "items": {
                            "type": "integer"
                        }
                    },
                    "style": "form",
                    "explode": true
                },
                {
                    "name": "name",
                    "in": "query",
                    "description": "Filter categories by name (searches in translations)",
                    "required": false,
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "enabled",
                    "in": "query",
                    "description": "Filter categories by enabled status",
                    "required": false,
                    "schema": {
                        "type": "boolean"
                    }
                },
                {
                    "name": "page",
                    "in": "query",
                    "description": "Page number",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "default": 1
                    }
                },
                {
                    "name": "per_page",
                    "in": "query",
                    "description": "Number of items per page",
                    "required": false,
                    "schema": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 100,
                        "default": 15
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Game categories list retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "type": "object",
                                        "properties": {
                                            "items": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/GameCategory"
                                                }
                                            },
                                            "meta": {
                                                "type": "object",
                                                "properties": {
                                                    "current_page": {
                                                        "type": "integer",
                                                        "example": 1
                                                    },
                                                    "last_page": {
                                                        "type": "integer",
                                                        "example": 10
                                                    },
                                                    "total": {
                                                        "type": "integer",
                                                        "example": 100
                                                    }
                                                }
                                            }
                                        }
                                    },
                                    "meta": {
                                        "type": "object",
                                        "properties": {
                                            "current_page": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "last_page": {
                                                "type": "integer",
                                                "example": 10
                                            },
                                            "total": {
                                                "type": "integer",
                                                "example": 100
                                            }
                                        }
                                    },
                                    "extra": {
                                        "type": "null"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "post": {
            "tags": [
                "Game Categories"
            ],
            "summary": "Create game category",
            "description": "Create a new game category with translations",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "required": [
                                "translations"
                            ],
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Category name",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "icon": {
                                    "type": "string",
                                    "description": "Category icon",
                                    "maxLength": 255,
                                    "nullable": true
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "description": "Whether category is enabled",
                                    "nullable": true
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "description": "Sort order",
                                    "minimum": 0,
                                    "nullable": true
                                },
                                "translations": {
                                    "type": "object",
                                    "description": "Translations for the category name",
                                    "additionalProperties": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "example": {
                                        "en": "Action",
                                        "zh-CN": "动作",
                                        "ja": "アクション"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Game category created successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/GameCategory"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    },
    "/game-categories/{id}": {
        "get": {
            "tags": [
                "Game Categories"
            ],
            "summary": "Get game category details",
            "description": "Get detailed information about a specific game category",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "description": "Game category ID",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Game category details retrieved successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/GameCategory"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Game category not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        },
        "put": {
            "tags": [
                "Game Categories"
            ],
            "summary": "Update game category",
            "description": "Update game category information with translations",
            "security": [
                {
                    "sanctum": []
                }
            ],
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "description": "Game category ID",
                    "required": true,
                    "schema": {
                        "type": "integer"
                    }
                }
            ],
            "requestBody": {
                "required": false,
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string",
                                    "description": "Category name",
                                    "maxLength": 255
                                },
                                "icon": {
                                    "type": "string",
                                    "description": "Category icon",
                                    "maxLength": 255
                                },
                                "enabled": {
                                    "type": "boolean",
                                    "description": "Whether category is enabled"
                                },
                                "sort_id": {
                                    "type": "integer",
                                    "description": "Sort order",
                                    "minimum": 0
                                },
                                "translations": {
                                    "type": "object",
                                    "description": "Translations for the category name",
                                    "additionalProperties": {
                                        "type": "string",
                                        "maxLength": 255
                                    },
                                    "example": {
                                        "en": "Action",
                                        "zh-CN": "动作",
                                        "ja": "アクション"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Game category updated successfully",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "code": {
                                        "type": "integer",
                                        "example": 0
                                    },
                                    "errmsg": {
                                        "type": "string",
                                        "example": ""
                                    },
                                    "data": {
                                        "$ref": "#/components/schemas/GameCategory"
                                    }
                                }
                            }
                        }
                    }
                },
                "401": {
                    "description": "Unauthorized",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Game category not found",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                },
                "422": {
                    "description": "Validation error",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ErrorResponse"
                            }
                        }
                    }
                }
            }
        }
    }
}